{
  "name": "cantica-studio",
  "displayName": "Cantica Studio",
  "description": "AI Actor Studio — build, connect, and run actor-ai agents backed by Cantica prompts",
  "version": "0.2.1",
  "publisher": "oliben67",
  "repository": {
    "type": "git",
    "url": "https://github.com/oliben67/cantica.git",
    "directory": "cantica-studio/vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "icon": "icons/icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cantica-studio",
          "title": "Cantica Studio",
          "icon": "icons/activitybar.svg"
        }
      ]
    },
    "views": {
      "cantica-studio": [
        {
          "id": "canticaScores.songbooksView",
          "name": "Songbooks"
        },
        {
          "id": "canticaScores.serversView",
          "name": "Servers"
        },
        {
          "id": "canticaScores.studioView",
          "name": "Studio"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "canticaScores.studioView",
        "contents": "Manage the local Studio API and settings.\n[▶  Start Studio API](command:canticaScores.startLocalStudio)\n[■  Stop Studio API](command:canticaScores.stopLocalStudio)\n[⚙  Configure Settings](command:canticaScores.configureServer)"
      }
    ],
    "commands": [
      {
        "command": "canticaScores.openPanel",
        "title": "Open Workspace",
        "category": "Cantica Studio",
        "icon": "$(open-preview)"
      },
      {
        "command": "canticaScores.newActor",
        "title": "Add AI Actor",
        "category": "Cantica Studio",
        "icon": "$(add)"
      },
      {
        "command": "canticaScores.saveGraph",
        "title": "Save Actor Graph",
        "category": "Cantica Studio",
        "icon": "$(save)"
      },
      {
        "command": "canticaScores.loadGraph",
        "title": "Reload Actor Graph",
        "category": "Cantica Studio",
        "icon": "$(refresh)"
      },
      {
        "command": "canticaScores.configureServer",
        "title": "Configure Servers",
        "category": "Cantica Studio",
        "icon": "$(settings-gear)"
      },
      {
        "command": "canticaScores.startLocalStudio",
        "title": "Start Studio API",
        "category": "Cantica Studio",
        "icon": "$(play)"
      },
      {
        "command": "canticaScores.stopLocalStudio",
        "title": "Stop Studio API",
        "category": "Cantica Studio",
        "icon": "$(debug-stop)"
      },
      {
        "command": "canticaScores.deleteActor",
        "title": "Delete Selected",
        "category": "Cantica Studio",
        "icon": "$(trash)"
      },
      {
        "command": "canticaScores.resetGraph",
        "title": "Reset Workspace",
        "category": "Cantica Studio",
        "icon": "$(clear-all)"
      },
      {
        "command": "canticaScores.editGraphFile",
        "title": "Edit Actor Graph",
        "category": "Cantica Studio",
        "icon": "$(edit)"
      },
      {
        "command": "canticaScores.newSongbook",
        "title": "New Songbook",
        "category": "Cantica Studio",
        "icon": "$(new-file)"
      },
      {
        "command": "canticaScores.saveAllSongbooks",
        "title": "Save All Songbooks",
        "category": "Cantica Studio",
        "icon": "$(save-all)"
      },
      {
        "command": "canticaScores.closeAllSongbooks",
        "title": "Close All Songbooks",
        "category": "Cantica Studio",
        "icon": "$(close-all)"
      },
      {
        "command": "canticaScores.newServer",
        "title": "New Cantica Server",
        "category": "Cantica Studio",
        "icon": "$(add)"
      },
      {
        "command": "canticaScores.deleteServer",
        "title": "Delete Cantica Server",
        "category": "Cantica Studio",
        "icon": "$(trash)"
      },
      {
        "command": "canticaScores.viewSongbook",
        "title": "View Songbook",
        "category": "Cantica Studio",
        "icon": "$(eye)"
      },
      {
        "command": "canticaScores.editSongbook",
        "title": "Edit Songbook",
        "category": "Cantica Studio",
        "icon": "$(edit)"
      },
      {
        "command": "canticaScores.deleteSongbook",
        "title": "Delete Songbook",
        "category": "Cantica Studio",
        "icon": "$(trash)"
      },
      {
        "command": "canticaScores.exportSongbook",
        "title": "Export",
        "category": "Cantica Studio",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "canticaScores.songbookViewTree",
        "title": "Switch to Tree View",
        "category": "Cantica Studio",
        "icon": "$(list-tree)"
      },
      {
        "command": "canticaScores.songbookViewList",
        "title": "Switch to List View",
        "category": "Cantica Studio",
        "icon": "$(list-unordered)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "canticaScores.newSongbook",
          "when": "view == canticaScores.songbooksView",
          "group": "navigation@1"
        },
        {
          "command": "canticaScores.saveAllSongbooks",
          "when": "view == canticaScores.songbooksView",
          "group": "navigation@2"
        },
        {
          "command": "canticaScores.closeAllSongbooks",
          "when": "view == canticaScores.songbooksView",
          "group": "navigation@3"
        },
        {
          "command": "canticaScores.songbookViewTree",
          "when": "view == canticaScores.songbooksView && canticaScores.songbookViewMode == 'list'",
          "group": "navigation@4"
        },
        {
          "command": "canticaScores.songbookViewList",
          "when": "view == canticaScores.songbooksView && canticaScores.songbookViewMode == 'tree'",
          "group": "navigation@4"
        },
        {
          "command": "canticaScores.newServer",
          "when": "view == canticaScores.serversView",
          "group": "navigation@1"
        },
        {
          "command": "canticaScores.deleteServer",
          "when": "view == canticaScores.serversView",
          "group": "navigation@2"
        },
        {
          "command": "canticaScores.startLocalStudio",
          "when": "view == canticaScores.studioView",
          "group": "navigation@1"
        },
        {
          "command": "canticaScores.stopLocalStudio",
          "when": "view == canticaScores.studioView",
          "group": "navigation@2"
        },
        {
          "command": "canticaScores.configureServer",
          "when": "view == canticaScores.studioView",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "canticaScores.viewSongbook",
          "when": "view == canticaScores.songbooksView && viewItem == songbook",
          "group": "1_open@1"
        },
        {
          "command": "canticaScores.editSongbook",
          "when": "view == canticaScores.songbooksView && viewItem == songbook",
          "group": "1_open@2"
        },
        {
          "command": "canticaScores.deleteSongbook",
          "when": "view == canticaScores.songbooksView && viewItem == songbook",
          "group": "2_manage@1"
        },
        {
          "command": "canticaScores.exportSongbook",
          "when": "view == canticaScores.songbooksView && viewItem == songbook",
          "group": "2_manage@2"
        }
      ],
      "explorer/context": [
        {
          "command": "canticaScores.editGraphFile",
          "when": "resourceExtname == .jsonld",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Cantica Studio",
      "properties": {
        "canticaScores.serverUrl": {
          "type": "string",
          "default": "http://localhost:8042",
          "markdownDescription": "Primary Cantica prompt server URL.",
          "scope": "machine-overridable",
          "order": 1
        },
        "canticaScores.servers": {
          "type": "array",
          "default": [],
          "markdownDescription": "Additional Cantica servers: `[{\"url\": \"https://...\", \"authToken\": \"\"}]`.",
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              },
              "authToken": {
                "type": "string",
                "default": ""
              }
            },
            "required": [
              "url"
            ]
          },
          "scope": "machine-overridable",
          "order": 2
        },
        "canticaScores.authToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "Bearer token for the primary Cantica server.",
          "scope": "machine-overridable",
          "order": 3
        },
        "canticaScores.explorerSide": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "left",
          "markdownDescription": "Side of the canvas where the prompt browser docks.",
          "scope": "window",
          "order": 4
        },
        "canticaScores.canticaHome": {
          "type": "string",
          "default": "",
          "markdownDescription": "Cantica home directory. Defaults to `~/.cantica`.",
          "scope": "machine-overridable",
          "order": 5
        },
        "canticaScores.studioPort": {
          "type": "number",
          "default": 8043,
          "markdownDescription": "Local port for the Studio API container.",
          "scope": "machine-overridable",
          "order": 6
        },
        "canticaScores.autoStartStudio": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Auto-start the Studio API container on activation.",
          "scope": "machine-overridable",
          "order": 7
        },
        "canticaScores.anthropicApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Anthropic API key (`ANTHROPIC_API_KEY`) injected into the Studio API container. Restart the Studio API after changing.",
          "scope": "machine",
          "order": 8
        },
        "canticaScores.openaiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "OpenAI API key (`OPENAI_API_KEY`) injected into the Studio API container. Restart the Studio API after changing.",
          "scope": "machine",
          "order": 9
        },
        "canticaScores.geminiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Google Gemini API key (`GEMINI_API_KEY`) injected into the Studio API container. Restart the Studio API after changing.",
          "scope": "machine",
          "order": 10
        },
        "canticaScores.githubToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "GitHub token (`GITHUB_TOKEN`) injected into the Studio API container. Required for the **Copilot** provider — either a personal access token or a Copilot-issued token. Falls back to the `GITHUB_TOKEN` environment variable if empty. Restart the Studio API after changing.",
          "scope": "machine",
          "order": 11
        },
        "canticaScores.providerModels": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "oneOf": [
              { "type": "array", "items": { "type": "string" }, "description": "Exact list of allowed model names" },
              { "type": "null", "description": "Any model name is accepted (open / unconstrained)" }
            ]
          },
          "markdownDescription": "Restrict which models are available per provider in the UI.\n\n- `\"claude\": [\"claude-3-5-sonnet-20241022\"]` — only that model shown for Claude\n- `\"gpt\": []` — GPT provider hidden entirely\n- `\"copilot\": null` — any model name accepted (no restriction)\n- omit a provider key — falls back to the built-in default model list\n\nChanges take effect immediately without reloading.",
          "scope": "window",
          "order": 11
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.webview.json",
    "lint": "eslint src webview-src",
    "lint:fix": "eslint src webview-src --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run lint && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@xyflow/react": "^12.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^3.0.0",
    "zustand": "^5.0.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0"
  }
}
