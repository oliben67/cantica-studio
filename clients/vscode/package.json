{
  "name": "cantica-studio",
  "displayName": "Cantica Studio",
  "description": "AI Actor Studio — build, connect, and run actor-ai agents backed by Cantica prompts",
  "version": "0.2.1",
  "publisher": "oliben67",
  "repository": {
    "type": "git",
    "url": "https://github.com/oliben67/cantica.git",
    "directory": "cantica-studio/vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "icon": "icons/icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cantica-studio",
          "title": "Cantica Studio",
          "icon": "icons/activitybar.svg"
        }
      ]
    },
    "views": {
      "cantica-studio": [
        {
          "id": "canticaScores.songbooksView",
          "name": "Songbooks"
        },
        {
          "id": "canticaScores.serversView",
          "name": "Cantica Servers"
        },
        {
          "id": "canticaScores.studioView",
          "name": "Studio"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "canticaScores.songbooksView",
        "contents": "No songbooks yet.\n[$(new-file)  New Songbook](command:canticaScores.newSongbook)\n[$(new-folder)  New Folder](command:canticaScores.newSongbookFolder)"
      }
    ],
    "commands": [
      {
        "command": "canticaScores.setupStudio",
        "title": "Setup Studio",
        "category": "Cantica Studio",
        "icon": "$(gear)"
      },
      {
        "command": "canticaScores.openPanel",
        "title": "Open Workspace",
        "category": "Cantica Studio",
        "icon": "$(open-preview)"
      },
      {
        "command": "canticaScores.newActor",
        "title": "Add AI Actor",
        "category": "Cantica Studio",
        "icon": "$(add)"
      },
      {
        "command": "canticaScores.saveGraph",
        "title": "Save Actor Graph",
        "category": "Cantica Studio",
        "icon": "$(save)"
      },
      {
        "command": "canticaScores.loadGraph",
        "title": "Reload Actor Graph",
        "category": "Cantica Studio",
        "icon": "$(refresh)"
      },
      {
        "command": "canticaScores.configureServer",
        "title": "Configure Servers",
        "category": "Cantica Studio",
        "icon": "$(settings-gear)"
      },
      {
        "command": "canticaScores.configureProviderKeys",
        "title": "Configure Providers",
        "category": "Cantica Studio",
        "icon": "$(wrench)"
      },
      {
        "command": "canticaScores.register",
        "title": "Register Client Key",
        "category": "Cantica Studio",
        "icon": "$(key)"
      },
      {
        "command": "canticaScores.unregister",
        "title": "Remove Client Key",
        "category": "Cantica Studio",
        "icon": "$(trash)"
      },
      {
        "command": "canticaScores.startLocalStudio",
        "title": "Start Studio API",
        "category": "Cantica Studio",
        "icon": "$(play)"
      },
      {
        "command": "canticaScores.stopLocalStudio",
        "title": "Stop Studio API",
        "category": "Cantica Studio",
        "icon": "$(debug-stop)"
      },
      {
        "command": "canticaScores.restartLocalStudio",
        "title": "Restart Studio API",
        "category": "Cantica Studio",
        "icon": "$(debug-restart)"
      },
      {
        "command": "canticaScores.deleteActor",
        "title": "Delete Selected",
        "category": "Cantica Studio",
        "icon": "$(trash)"
      },
      {
        "command": "canticaScores.resetGraph",
        "title": "Reset Workspace",
        "category": "Cantica Studio",
        "icon": "$(clear-all)"
      },
      {
        "command": "canticaScores.editGraphFile",
        "title": "Edit Actor Graph",
        "category": "Cantica Studio",
        "icon": "$(edit)"
      },
      {
        "command": "canticaScores.newSongbook",
        "title": "New Songbook",
        "category": "Cantica Studio",
        "icon": "$(new-file)"
      },
      {
        "command": "canticaScores.saveAllSongbooks",
        "title": "Save All Songbooks",
        "category": "Cantica Studio",
        "icon": "$(save-all)"
      },
      {
        "command": "canticaScores.closeAllSongbooks",
        "title": "Close All Songbooks",
        "category": "Cantica Studio",
        "icon": "$(close-all)"
      },
      {
        "command": "canticaScores.newServer",
        "title": "New Cantica Server",
        "category": "Cantica Studio",
        "icon": "$(add)"
      },
      {
        "command": "canticaScores.deleteServer",
        "title": "Delete Cantica Server",
        "category": "Cantica Studio",
        "icon": "$(trash)"
      },
      {
        "command": "canticaScores.viewSongbook",
        "title": "View Songbook",
        "category": "Cantica Studio",
        "icon": "$(eye)"
      },
      {
        "command": "canticaScores.editSongbook",
        "title": "Edit Songbook",
        "category": "Cantica Studio",
        "icon": "$(edit)"
      },
      {
        "command": "canticaScores.deleteSongbook",
        "title": "Delete Songbook",
        "category": "Cantica Studio",
        "icon": "$(trash)"
      },
      {
        "command": "canticaScores.exportSongbook",
        "title": "Export",
        "category": "Cantica Studio",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "canticaScores.songbookViewTree",
        "title": "Switch to Tree View",
        "category": "Cantica Studio",
        "icon": "$(list-tree)"
      },
      {
        "command": "canticaScores.songbookViewList",
        "title": "Switch to List View",
        "category": "Cantica Studio",
        "icon": "$(list-unordered)"
      },
      {
        "command": "canticaScores.newSongbookFolder",
        "title": "New Folder",
        "category": "Cantica Studio",
        "icon": "$(new-folder)"
      },
      {
        "command": "canticaScores.newSongbookInFolder",
        "title": "New Songbook in Folder",
        "category": "Cantica Studio",
        "icon": "$(new-file)"
      },
      {
        "command": "canticaScores.renameSongbook",
        "title": "Rename",
        "category": "Cantica Studio",
        "icon": "$(pencil)"
      },
      {
        "command": "canticaScores.renameSongbookFolder",
        "title": "Rename Folder",
        "category": "Cantica Studio",
        "icon": "$(pencil)"
      },
      {
        "command": "canticaScores.deleteSongbookFolder",
        "title": "Delete Folder",
        "category": "Cantica Studio",
        "icon": "$(trash)"
      },
      {
        "command": "canticaScores.revealSongbook",
        "title": "Reveal in File Explorer",
        "category": "Cantica Studio"
      },
      {
        "command": "canticaScores.copySongbook",
        "title": "Copy",
        "category": "Cantica Studio",
        "icon": "$(copy)"
      },
      {
        "command": "canticaScores.pasteSongbook",
        "title": "Paste",
        "category": "Cantica Studio",
        "icon": "$(clippy)"
      },
      {
        "command": "canticaScores.openCanticaFile",
        "title": "Open File",
        "category": "Cantica Studio",
        "icon": "$(go-to-file)"
      },
      {
        "command": "canticaScores.newFolderInFolder",
        "title": "New Folder",
        "category": "Cantica Studio",
        "icon": "$(new-folder)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "canticaScores.newSongbook",
          "when": "view == canticaScores.songbooksView",
          "group": "navigation@1"
        },
        {
          "command": "canticaScores.saveAllSongbooks",
          "when": "view == canticaScores.songbooksView",
          "group": "navigation@3"
        },
        {
          "command": "canticaScores.closeAllSongbooks",
          "when": "view == canticaScores.songbooksView",
          "group": "navigation@4"
        },
        {
          "command": "canticaScores.songbookViewTree",
          "when": "view == canticaScores.songbooksView && canticaScores.songbookViewMode == 'list'",
          "group": "navigation@5"
        },
        {
          "command": "canticaScores.songbookViewList",
          "when": "view == canticaScores.songbooksView && canticaScores.songbookViewMode == 'tree'",
          "group": "navigation@5"
        },
        {
          "command": "canticaScores.newServer",
          "when": "view == canticaScores.serversView",
          "group": "navigation@1"
        },
        {
          "command": "canticaScores.deleteServer",
          "when": "view == canticaScores.serversView",
          "group": "navigation@2"
        },
        {
          "command": "canticaScores.register",
          "when": "view == canticaScores.studioView && !canticaScores.isRegistered",
          "group": "navigation@1"
        },
        {
          "command": "canticaScores.unregister",
          "when": "view == canticaScores.studioView && canticaScores.isRegistered",
          "group": "navigation@1"
        },
        {
          "command": "canticaScores.startLocalStudio",
          "when": "view == canticaScores.studioView && config.canticaScores.studioMode == local",
          "group": "navigation@1"
        },
        {
          "command": "canticaScores.stopLocalStudio",
          "when": "view == canticaScores.studioView && config.canticaScores.studioMode == local",
          "group": "navigation@2"
        },
        {
          "command": "canticaScores.restartLocalStudio",
          "when": "view == canticaScores.studioView && config.canticaScores.studioMode == local",
          "group": "navigation@3"
        },
        {
          "command": "canticaScores.configureServer",
          "when": "view == canticaScores.studioView",
          "group": "navigation@4"
        },
        {
          "command": "canticaScores.newSongbookFolder",
          "when": "view == canticaScores.songbooksView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "canticaScores.viewSongbook",
          "when": "view == canticaScores.songbooksView && viewItem == songbook",
          "group": "1_open@1"
        },
        {
          "command": "canticaScores.editSongbook",
          "when": "view == canticaScores.songbooksView && viewItem == songbook",
          "group": "1_open@2"
        },
        {
          "command": "canticaScores.exportSongbook",
          "when": "view == canticaScores.songbooksView && viewItem == songbook",
          "group": "2_manage@2"
        },
        {
          "command": "canticaScores.openCanticaFile",
          "when": "view == canticaScores.songbooksView && viewItem == canticaFile",
          "group": "1_open@1"
        },
        {
          "command": "canticaScores.renameSongbook",
          "when": "view == canticaScores.songbooksView && (viewItem == songbook || viewItem == canticaFile)",
          "group": "2_manage@0"
        },
        {
          "command": "canticaScores.deleteSongbook",
          "when": "view == canticaScores.songbooksView && (viewItem == songbook || viewItem == canticaFile)",
          "group": "2_manage@1"
        },
        {
          "command": "canticaScores.revealSongbook",
          "when": "view == canticaScores.songbooksView && (viewItem == songbook || viewItem == canticaFile)",
          "group": "3_explore@1"
        },
        {
          "command": "canticaScores.copySongbook",
          "when": "view == canticaScores.songbooksView && (viewItem == songbook || viewItem == canticaFile)",
          "group": "4_clipboard@1"
        },
        {
          "command": "canticaScores.pasteSongbook",
          "when": "view == canticaScores.songbooksView && (viewItem == songbook || viewItem == canticaFile)",
          "group": "4_clipboard@2"
        },
        {
          "command": "canticaScores.renameSongbook",
          "when": "view == canticaScores.songbooksView && (viewItem == songbook || viewItem == canticaFile)",
          "group": "inline@1"
        },
        {
          "command": "canticaScores.newSongbookInFolder",
          "when": "view == canticaScores.songbooksView && viewItem == canticaFolder",
          "group": "1_new@1"
        },
        {
          "command": "canticaScores.newFolderInFolder",
          "when": "view == canticaScores.songbooksView && viewItem == canticaFolder",
          "group": "1_new@2"
        },
        {
          "command": "canticaScores.pasteSongbook",
          "when": "view == canticaScores.songbooksView && viewItem == canticaFolder",
          "group": "1_new@3"
        },
        {
          "command": "canticaScores.renameSongbookFolder",
          "when": "view == canticaScores.songbooksView && viewItem == canticaFolder",
          "group": "2_manage@1"
        },
        {
          "command": "canticaScores.deleteSongbookFolder",
          "when": "view == canticaScores.songbooksView && viewItem == canticaFolder",
          "group": "2_manage@2"
        },
        {
          "command": "canticaScores.revealSongbook",
          "when": "view == canticaScores.songbooksView && viewItem == canticaFolder",
          "group": "3_explore@1"
        },
        {
          "command": "canticaScores.renameSongbookFolder",
          "when": "view == canticaScores.songbooksView && viewItem == canticaFolder",
          "group": "inline@1"
        },
        {
          "command": "canticaScores.deleteSongbookFolder",
          "when": "view == canticaScores.songbooksView && viewItem == canticaFolder",
          "group": "inline@2"
        }
      ],
      "explorer/context": [
        {
          "command": "canticaScores.editGraphFile",
          "when": "resourceExtname == .jsonld",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Cantica Studio",
      "properties": {
        "canticaScores.serverUrl": {
          "type": "string",
          "default": "http://localhost:8042",
          "markdownDescription": "Primary Cantica prompt server URL.",
          "scope": "machine-overridable",
          "order": 1
        },
        "canticaScores.servers": {
          "type": "array",
          "default": [],
          "markdownDescription": "Additional Cantica servers: `[{\"url\": \"https://...\", \"authToken\": \"\"}]`.",
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              },
              "authToken": {
                "type": "string",
                "default": ""
              }
            },
            "required": [
              "url"
            ]
          },
          "scope": "machine-overridable",
          "order": 2
        },
        "canticaScores.authToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "Bearer token for the primary Cantica server.",
          "scope": "machine-overridable",
          "order": 3
        },
        "canticaScores.explorerSide": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "left",
          "markdownDescription": "Side of the canvas where the prompt browser docks.",
          "scope": "window",
          "order": 4
        },
        "canticaScores.canticaHome": {
          "type": "string",
          "default": "",
          "markdownDescription": "Cantica home directory. Defaults to `~/.cantica`.",
          "scope": "machine-overridable",
          "order": 5
        },
        "canticaScores.studioMode": {
          "type": "string",
          "enum": [
            "local",
            "remote"
          ],
          "enumDescriptions": [
            "Manage a local Docker container. The extension starts, stops, and injects API keys automatically.",
            "Connect to an existing Studio API server. Configure the URL below; API keys are managed server-side."
          ],
          "default": "local",
          "markdownDescription": "How the extension connects to the Studio API.\n\n- **local** — Docker container managed by the extension (configure port and API keys below)\n- **remote** — existing server; set `#canticaScores.studioUrl#` to its base URL",
          "scope": "machine-overridable",
          "order": 6
        },
        "canticaScores.studioRunMode": {
          "type": "string",
          "enum": ["container", "native"],
          "enumDescriptions": [
            "Run Studio API in a Docker container (requires Docker Desktop).",
            "Run Studio API as a native process using the 'studio' CLI (requires pip install)."
          ],
          "default": "container",
          "markdownDescription": "_(local mode only)_ How to start the Studio API locally. Set automatically by the Setup wizard.",
          "scope": "machine-overridable",
          "order": 7
        },
        "canticaScores.studioUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "Studio API base URL used when `#canticaScores.studioMode#` is **remote** (e.g. `https://studio.example.com`). Ignored in **local** mode.",
          "scope": "machine-overridable",
          "order": 8
        },
        "canticaScores.studioPort": {
          "type": "number",
          "default": 8043,
          "markdownDescription": "_(local mode only)_ Host port mapped to the Studio API container.",
          "scope": "machine-overridable",
          "order": 8
        },
        "canticaScores.autoStartStudio": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "_(local mode only)_ Auto-start the Studio API container when the extension activates.",
          "scope": "machine-overridable",
          "order": 9
        }
      }
    },
    "keybindings": [
      {
        "key": "f2",
        "command": "canticaScores.renameSongbook",
        "when": "focusedView == 'canticaScores.songbooksView' && viewItem == 'songbook'"
      },
      {
        "key": "f2",
        "command": "canticaScores.renameSongbookFolder",
        "when": "focusedView == 'canticaScores.songbooksView' && viewItem == 'songbookFolder'"
      },
      {
        "key": "delete",
        "command": "canticaScores.deleteSongbook",
        "when": "focusedView == 'canticaScores.songbooksView' && viewItem == 'songbook'"
      },
      {
        "key": "backspace",
        "command": "canticaScores.deleteSongbook",
        "when": "focusedView == 'canticaScores.songbooksView' && viewItem == 'songbook'"
      },
      {
        "key": "delete",
        "command": "canticaScores.deleteSongbookFolder",
        "when": "focusedView == 'canticaScores.songbooksView' && viewItem == 'songbookFolder'"
      },
      {
        "key": "backspace",
        "command": "canticaScores.deleteSongbookFolder",
        "when": "focusedView == 'canticaScores.songbooksView' && viewItem == 'songbookFolder'"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.webview.json",
    "lint": "eslint src webview-src",
    "lint:fix": "eslint src webview-src --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run lint && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@xyflow/react": "^12.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0"
  }
}
