{
  "name": "cantica-studio",
  "displayName": "Cantica Studio",
  "description": "AI Actor Studio — build, connect, and run actor-ai agents backed by Cantica prompts",
  "version": "0.2.0",
  "publisher": "oliben67",
  "repository": {
    "type": "git",
    "url": "https://github.com/oliben67/cantica.git",
    "directory": "cantica-studio/vscode"
  },
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "cantica-studio", "title": "Cantica Studio", "icon": "icons/activitybar.svg" }
      ]
    },
    "views": {
      "cantica-studio": [
        { "id": "canticaScores.agentsView", "name": "AI Actors", "icon": "icons/activitybar.svg" }
      ]
    },
    "viewsWelcome": [
      {
        "view": "canticaScores.agentsView",
        "contents": "Start the local Studio API (Docker required).\n[Start Studio API](command:canticaScores.startLocalStudio)\nOr connect to an existing server.\n[Configure](command:canticaScores.configureServer)",
        "when": "!canticaScores.hasAgents"
      }
    ],
    "commands": [
      { "command": "canticaScores.openPanel",        "title": "Open Actor Studio",   "category": "Cantica Studio", "icon": "$(open-preview)" },
      { "command": "canticaScores.newActor",          "title": "Add AI Actor",        "category": "Cantica Studio", "icon": "$(add)" },
      { "command": "canticaScores.saveGraph",         "title": "Save Actor Graph",    "category": "Cantica Studio", "icon": "$(save)" },
      { "command": "canticaScores.loadGraph",         "title": "Reload Actor Graph",  "category": "Cantica Studio", "icon": "$(refresh)" },
      { "command": "canticaScores.configureServer",   "title": "Configure Servers",   "category": "Cantica Studio", "icon": "$(settings-gear)" },
      { "command": "canticaScores.startLocalStudio",  "title": "Start Studio API",    "category": "Cantica Studio", "icon": "$(play)" },
      { "command": "canticaScores.stopLocalStudio",   "title": "Stop Studio API",     "category": "Cantica Studio", "icon": "$(debug-stop)" }
    ],
    "menus": {
      "view/title": [
        { "command": "canticaScores.openPanel",        "when": "view == canticaScores.agentsView", "group": "navigation@1" },
        { "command": "canticaScores.newActor",         "when": "view == canticaScores.agentsView", "group": "navigation@2" },
        { "command": "canticaScores.saveGraph",        "when": "view == canticaScores.agentsView", "group": "navigation@3" },
        { "command": "canticaScores.configureServer",  "when": "view == canticaScores.agentsView", "group": "navigation@4" },
        { "command": "canticaScores.startLocalStudio", "when": "view == canticaScores.agentsView", "group": "navigation@5" },
        { "command": "canticaScores.stopLocalStudio",  "when": "view == canticaScores.agentsView", "group": "navigation@6" }
      ]
    },
    "configuration": {
      "title": "Cantica Studio",
      "properties": {
        "canticaScores.serverUrl": {
          "type": "string", "default": "http://localhost:8042",
          "markdownDescription": "Primary Cantica prompt server URL.",
          "scope": "machine-overridable", "order": 1
        },
        "canticaScores.servers": {
          "type": "array", "default": [],
          "markdownDescription": "Additional Cantica servers: `[{\"url\": \"https://...\", \"authToken\": \"\"}]`.",
          "items": {
            "type": "object",
            "properties": { "url": { "type": "string" }, "authToken": { "type": "string", "default": "" } },
            "required": ["url"]
          },
          "scope": "machine-overridable", "order": 2
        },
        "canticaScores.authToken": {
          "type": "string", "default": "",
          "markdownDescription": "Bearer token for the primary Cantica server.",
          "scope": "machine-overridable", "order": 3
        },
        "canticaScores.explorerSide": {
          "type": "string", "enum": ["left", "right"], "default": "left",
          "markdownDescription": "Side of the canvas where the prompt browser docks.",
          "scope": "window", "order": 4
        },
        "canticaScores.canticaHome": {
          "type": "string", "default": "",
          "markdownDescription": "Cantica home directory. Defaults to `~/.cantica`.",
          "scope": "machine-overridable", "order": 5
        },
        "canticaScores.studioPort": {
          "type": "number", "default": 8043,
          "markdownDescription": "Local port for the Studio API container.",
          "scope": "machine-overridable", "order": 6
        },
        "canticaScores.autoStartStudio": {
          "type": "boolean", "default": true,
          "markdownDescription": "Auto-start the Studio API container on activation.",
          "scope": "machine-overridable", "order": 7
        },
        "canticaScores.graphFile": {
          "type": "string", "default": ".vscode/actors.jsonld",
          "markdownDescription": "Workspace-relative path to the actor graph JSON-LD file.",
          "scope": "resource", "order": 8
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.webview.json",
    "lint": "eslint src webview-src",
    "lint:fix": "eslint src webview-src --fix",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "@xyflow/react": "^12.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zustand": "^5.0.0"
  }
}
